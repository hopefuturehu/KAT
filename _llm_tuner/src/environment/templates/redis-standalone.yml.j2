version: "3.9"
services:
  redis:
    image: {{ image | default("redis:7.2-alpine") }}
    ports:
      - "{{ host_port | default(6379) }}:6379"
    mem_limit: {{ memory_limit | default("8g") }}
    cpus: "{{ cpu_limit | default(4) }}"
    volumes:
      - {{ config_mount | default("./redis.conf") }}:/usr/local/etc/redis/redis.conf:ro
    command: redis-server /usr/local/etc/redis/redis.conf
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 3
